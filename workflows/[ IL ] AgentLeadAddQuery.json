    {
      "parameters": {
        "jsCode": "// Loop over input items\nfor (const item of $input.all()) {\n  // Extract the \"content\" field from the JSON\n  const content = item.json.choices[0].message.content;\n\n  // Remove surrounding quotes and split by commas\n  const contentWithoutQuotes = content.replace(/^\"|\"$/g, ''); // Убираем кавычки в начале и конце\n  const contentArray = contentWithoutQuotes.split('\",\"'); // Разбиваем по запятым и кавычкам\n\n  // Add the extracted data to the JSON as a new field\n  item.json.contentArray = contentArray;\n}\n\n// Return the modified items\nreturn $input.all();"
      },
