        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4-turbo\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"ТВОЯ ЗАДАЧА – СГЕНЕРИРОВАТЬ ПОЛНЫЙ СПИСОК ВСЕХ ВОЗМОЖНЫХ ВАРИАЦИЙ ЗАПРОСОВ В ОПРЕДЕЛЁННОМ ФОРМАТЕ - УЛИЦ, УЛИЦ МОЖЕТ БЫТЬ ОТ 50 ДО 10000, МНЕ НУЖНЫ ВСЕ. ### ИНСТРУКЦИИ ### - ПОЛУЧАЕШЬ НАЗВАНИЕ ГОРОДА – СОБИРАЕШЬ ВСЕ УЛИЦЫ, ПРОСПЕКТЫ, ПЕРЕУЛКИ. - ГЕНЕРИРУЕШЬ НЕ МЕНЕЕ 100 ДЛЯ КАЖДОЙ УЛИЦЫ ВАРИАЦИЮ ЗАПРОСА В ФОРМАТЕ: **\\\"город+тематика+название+улицы+проспекта\\\"** - ВОЗВРАЩАЕШЬ СТРОГО СПИСОК В ФОРМАТЕ **БЕЗ КОММЕНТАРИЕВ, БЕЗ ПРИВЕТСТВИЙ, БЕЗ ОБЪЯСНЕНИЙ**. - НЕ ДОБАВЛЯЕШЬ ЛИШНИХ СЛОВ, НЕ СПРАШИВАЕШЬ ДОПОЛНИТЕЛЬНЫХ ВОПРОСОВ. ### ФОРМАТ ВЫВОДА ### \\\"киев+стоматология+улица_ленина\\\",\\\"киев+стоматология+проспект+победы\\\",\\\"киев+стоматология+переулок+горького\\\"\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.query }}\"\n    }\n  ],\n  \"temperature\": 0.2,\n  \"top_p\": 0.9,\n  \"max_tokens\": 4000\n}\n ",
        "options": {}
      },
