    {
      "parameters": {
        "jsCode": "// Получаем очищенный текст из предыдущего шага\nconst cleanText = $json.cleanText;\n\n// Регулярное выражение для поиска email\nconst emailRegex = /[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.(?!png|jpg|gif|jpeg)[a-zA-Z]{2,}/g;\n\n// Регулярное выражение для поиска телефонов (UA)\nconst phoneRegex = /(?:\\+?380|0)\\s?\\(?\\d{2}\\)?[\\s\\-]?\\d{3}[\\s\\-]?\\d{2}[\\s\\-]?\\d{2}/g;\n\n// Регулярка для Instagram ссылок\nconst instagramRegex = /(?:https?:\\/\\/)?(?:www\\.)?instagram\\.com\\/[a-zA-Z0-9._%-]+/gi;\n\n// Извлекаем email\nconst emails = cleanText.match(emailRegex) || [];\n\n// Извлекаем телефоны\nconst phones = cleanText.match(phoneRegex) || [];\n\n// Извлекаем Instagram\nconst instagramLinks = cleanText.match(instagramRegex) || [];\n\n// Возвращаем результат\nreturn {\n  json: {\n    emails: emails,\n    phones: phones,\n    instagram: instagramLinks\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
