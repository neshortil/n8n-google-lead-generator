    {
      "parameters": {
        "jsCode": "// Получаем HTML-код страницы\nconst data = $json.data;\n\n// Очищаем HTML от стилей и скриптов\nconst cleanHTML = data.replace(/<script\\b[^<]*(?:(?!<\\/script>)<[^<]*)*<\\/script>|<style\\b[^<]*(?:(?!<\\/style>)<[^<]*)*<\\/style>/gi, '');\n\n// Извлекаем содержимое тега <body>\nconst bodyMatch = cleanHTML.match(/<body[^>]*>([\\s\\S]*?)<\\/body>/i);\nconst bodyContent = bodyMatch ? bodyMatch[1] : '';\n\n// Получаем чистый текст из <body>\nconst cleanText = bodyContent.replace(/<[^>]+>/g, '').replace(/\\s+/g, ' ').trim();\n\n// Возвращаем результат\nreturn {\n  json: {\n    cleanText: cleanText\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2208,
        304
      ],
      "id": "9a09d0ff-859d-4837-b994-812ed906c966",
