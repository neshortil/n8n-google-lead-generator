      "parameters": {
        "jsCode": "// Получаем входные данные\nconst inputData = $input.all();\n\n// Обрабатываем каждый элемент входных данных\nconst result = inputData.map(item => {\n  // Получаем массив телефонов\n  const phonesArray = item.json.phones || [];\n\n  // Преобразуем массив в строку, разделяя элементы запятыми\n  const phonesString = phonesArray.join(', ');\n\n  // Возвращаем результат\n  return {\n    json: {\n      phonesString: phonesString\n    }\n  };\n});\n\n// Возвращаем результат\nreturn result;"
